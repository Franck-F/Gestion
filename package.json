{
  "name": "gestion",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "db:migrate": "cd server && npx prisma migrate dev",
    "db:seed": "cd server && npx prisma db seed",
    "db:studio": "cd server && npx prisma studio",
    "build": "cd client && npm run build",
    "vercel-build": "cd client && npm run build",
    "postinstall": "npx prisma generate --schema=server/prisma/schema.prisma || true"
  },
  "dependencies": {
    "@google/genai": "^1.47.0",
    "@prisma/client": "^6.0.0",
    "@supabase/supabase-js": "^2.101.0",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.2",
    "firecrawl": "^4.18.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "resend": "^6.10.0",
    "uuid": "^10.0.0",
    "web-push": "^3.6.7",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "prisma": "^6.0.0"
  }
}
